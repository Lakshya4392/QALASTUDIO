# Backend Environment Variables Template
# Copy this file to .env and fill in your actual values
# ⚠️ NEVER commit .env to git - it's in .gitignore

# Database
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require

# Redis (Optional - for caching)
REDIS_URL=rediss://default:password@your-redis-host:6379

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-change-this-in-production
JWT_EXPIRES_IN=7d

# Gemini AI API (Google)
GEMINI_API_KEY=AIzaSy...

# Cloudinary (Image Uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email (Zoho)
ZOHO_EMAIL=your-email@yourdomain.com
ZOHO_APP_PASSWORD=your-zoho-app-password
ADMIN_EMAIL=admin@qalastudios.com
